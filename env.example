# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# ⚠️ Use the SERVICE ROLE key, not the anon/public key. The service role key
# bypasses Row Level Security and must NEVER be exposed to the browser —
# only set it as a server-side env var in Vercel. Never prefix it with
# NEXT_PUBLIC_.

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
